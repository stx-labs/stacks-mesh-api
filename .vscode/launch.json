{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch: API",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch"],
      "args": ["${workspaceFolder}/packages/api/src/index.ts"],
      "cwd": "${workspaceFolder}/packages/api",
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development"
      },
      "preLaunchTask": "build",
      "skipFiles": ["<node_internals>/**"],
      "killBehavior": "polite",
    }
  ]
}
