{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "api: run",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch"],
      "args": ["${workspaceFolder}/packages/api/src/index.ts"],
      "cwd": "${workspaceFolder}/packages/api",
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development"
      },
      "preLaunchTask": "build",
      "skipFiles": ["<node_internals>/**"],
      "killBehavior": "polite",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "api: test",
      "runtimeArgs": ["--import", "tsx"],
      "args": [
        "--test",
        // "--test-name-pattern", "/network",
        "tests/api/**/*.test.ts"
      ],
      "cwd": "${workspaceFolder}/packages/api",
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test",
      },
      "preLaunchTask": "build",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "construction: test",
      "runtimeArgs": ["--import", "tsx"],
      "args": [
        "--test",
        "--test-name-pattern", "Mesh CLI",
        "tests/construction/**/*.test.ts"
      ],
      "cwd": "${workspaceFolder}/packages/api",
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test",
      },
      "preLaunchTask": "build",
    },
  ]
}
