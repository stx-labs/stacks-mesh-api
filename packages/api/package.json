{
  "name": "@stacks/mesh-api",
  "version": "0.4.4",
  "description": "Mesh API implementation for Stacks blockchain",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "generate:git-info": "rimraf .git-info && ../../node_modules/.bin/api-toolkit-git-info",
    "generate:openapi": "rimraf ./openapi.yaml && tsx src/openapi-generator.ts",
    "test:api": "NODE_ENV=test node --test --import tsx --test-timeout 300000 tests/api/**/*.test.ts",
    "test:construction": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/**/*.test.ts",
    "test:construction:mesh-cli": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/mesh-cli.test.ts",
    "test:construction:derive": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/derive.test.ts",
    "test:construction:hash": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/hash.test.ts",
    "test:construction:combine": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/combine.test.ts",
    "test:construction:parse": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/parse.test.ts",
    "test:construction:metadata": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/metadata.test.ts",
    "test:construction:payloads": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/payloads.test.ts",
    "test:construction:preprocess": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/preprocess.test.ts",
    "test:construction:submit": "NODE_ENV=test node --test --test-concurrency 1 --import tsx --test-timeout 300000 tests/construction/submit.test.ts"
  },
  "keywords": [
    "stacks",
    "mesh",
    "rosetta",
    "blockchain",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stx-labs/stacks-mesh-api",
    "directory": "packages/api"
  },
  "prettier": "@stacks/prettier-config",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.48",
    "@stacks/api-toolkit": "^1.13.0",
    "@stacks/codec": "^1.6.0",
    "@stacks/mesh-schemas": "*",
    "@stacks/rpc-client": "^2.0.1",
    "@stacks/transactions": "^7.3.1",
    "bignumber.js": "^10.0.2",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.2",
    "lru-cache": "^11.2.6",
    "undici": "^7.20.0"
  },
  "devDependencies": {
    "@fastify/swagger": "^9.7.0",
    "@stacks/api-test-toolkit": "^1.13.0",
    "@stacks/prettier-config": "^0.0.10",
    "@types/node": "^22.12.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tsdoc": "^0.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
