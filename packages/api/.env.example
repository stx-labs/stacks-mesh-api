# Server configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Stacks network: mainnet or testnet
STACKS_NETWORK=mainnet

# Stacks RPC URL (optional - defaults based on network)
# STACKS_RPC_URL=https://stacks-node-api.mainnet.stacks.co

# Stacks RPC API key (optional - for authenticated endpoints)
# STACKS_RPC_API_KEY=your-api-key
