{
  "name": "@stacks/mesh-serializer",
  "version": "1.0.0",
  "description": "Mesh API serializer for Stacks blockchain transactions and blocks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "stacks",
    "mesh",
    "rosetta",
    "blockchain",
    "serializer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stx-labs/stacks-mesh-api",
    "directory": "packages/mesh-serializer"
  },
  "license": "MIT",
  "dependencies": {
    "@hirosystems/stacks-encoding-native-js": "file:../../../stacks-encoding-native-js"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
