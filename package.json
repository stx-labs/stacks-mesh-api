{
  "name": "stacks-mesh-api",
  "version": "0.4.2",
  "private": true,
  "description": "Mesh API implementation for Stacks blockchain - monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @stacks/mesh-schemas && npm run build -w @stacks/mesh-api",
    "clean": "npm run clean --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev -w @stacks/mesh-api",
    "start": "npm run start -w @stacks/mesh-api"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stx-labs/stacks-mesh-api"
  },
  "prettier": "@stacks/prettier-config",
  "license": "MIT",
  "devDependencies": {
    "@stacks/prettier-config": "^0.0.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tsdoc": "^0.5.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
