{
  "name": "stacks-mesh-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Mesh API implementation for Stacks blockchain - monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @stacks/mesh-serializer && npm run build -w @stacks/mesh-api",
    "clean": "npm run clean --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev -w @stacks/mesh-api",
    "start": "npm run start -w @stacks/mesh-api"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stx-labs/stacks-mesh-api"
  },
  "prettier": "@stacks/prettier-config",
  "license": "MIT",
  "devDependencies": {
    "@stacks/prettier-config": "^0.0.10",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
